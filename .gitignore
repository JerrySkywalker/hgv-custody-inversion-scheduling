############################################
# Project results: ignore generated outputs
############################################
results/**

# Keep directory skeleton
!results/.gitkeep
!results/cache/
!results/figs/
!results/logs/
!results/tables/
!results/bundles/
!results/cache/.gitkeep
!results/figs/.gitkeep
!results/logs/.gitkeep
!results/tables/.gitkeep
!results/bundles/.gitkeep

# Optional: ignore debug subfolders
results/figs/debug/**
results/cache/debug/**
results/logs/debug/**

############################################
# Milestone outputs
############################################
/output/milestones/**/cache/
/output/milestones/**/figures/
/output/milestones/**/tables/
/output/milestones/**/reports/
/output/milestones/*.md
!/output/.gitkeep
!/output/milestones/.gitkeep
!/output/milestones/**/cache/.gitkeep
!/output/milestones/**/figures/.gitkeep
!/output/milestones/**/tables/.gitkeep
!/output/milestones/**/reports/.gitkeep

# Optional packaged milestone archives
/dist/milestones/
*.milestone.zip

