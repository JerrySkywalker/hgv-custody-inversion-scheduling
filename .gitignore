# MATLAB / Simulink
############################################
*.asv
*.m~
*.mlx.autosave
*.slxc
*.autosave
*.fig~
slprj/
codegen/
resources/project/
*.mex*
*.p

############################################
# OS / Editor junk
############################################
.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/
*.swp
*.swo
*~

############################################
# Python helpers (if any)
############################################
__pycache__/
*.pyc
*.pyo

############################################
# Logs / temp
############################################
*.log
tmp/
temp/
scratch/

############################################
# Project results: ignore all generated outputs
############################################
results/**

# Keep result directory skeleton
!results/.gitkeep
!results/cache/
!results/figs/
!results/logs/
!results/tables/
!results/bundles/

!results/cache/.gitkeep
!results/figs/.gitkeep
!results/logs/.gitkeep
!results/tables/.gitkeep
!results/bundles/.gitkeep

############################################
# Optional: debug figure subfolders (ignored by default)
############################################
results/figs/debug/**
results/cache/debug/**
results/logs/debug/**

############################################
# Optional: keep released paper outputs under version control
# Uncomment these if you want final figures/tables tracked
############################################
# !paper_outputs/
# !paper_outputs/**
# !reference/
# !reference/**
# !tests/baselines/
# !tests/baselines/**

############################################
# Archives / large generated bundles
############################################
*.zip
*.7z
*.tar
*.tar.gz

