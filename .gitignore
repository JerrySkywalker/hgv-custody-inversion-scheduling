__pycache__/
*.pyc
*.pyo

############################################
# Logs / temp
############################################
*.log
tmp/
temp/
scratch/

############################################
# Project results: ignore generated outputs
############################################
results/**

# Keep directory skeleton
!results/.gitkeep
!results/cache/
!results/figs/
!results/logs/
!results/tables/
!results/bundles/
!results/cache/.gitkeep
!results/figs/.gitkeep
!results/logs/.gitkeep
!results/tables/.gitkeep
!results/bundles/.gitkeep

# Optional: ignore debug subfolders
results/figs/debug/**
results/cache/debug/**
results/logs/debug/**

############################################
# Optional: keep released paper outputs (uncomment if needed)
############################################
# !paper_outputs/
# !paper_outputs/**
# !reference/
# !reference/**
# !tests/baselines/
# !tests/baselines/**

############################################
# Archives / large bundles
############################################
*.zip
*.7z
*.tar
*.tar.gz

############################################
# Git LFS: uncomment if using LFS for large binaries
############################################
# *.mat
# *.png
# *.pdf
# *.csv

############################################
# Deliverables: track milestone outputs
############################################
!deliverables/
!deliverables/milestone_*/
!deliverables/milestone_*/**

############################################
# Milestone scripts and docs: always tracked
############################################
!milestones/
!milestones/**

############################################
# Optional: ignore large exported binaries (uncomment if repo too large)
############################################
# deliverables/**/figs/*.png
# deliverables/**/figs/*.pdf
