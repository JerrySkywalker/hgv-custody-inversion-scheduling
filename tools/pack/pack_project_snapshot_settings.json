{
  "skip_dirs": [
    ".git",
    ".vs",
    ".vscode",
    "outputs",
    "snapshots"
  ],
  "code_allowed_ext": [
    ".m",
    ".ps1",
    ".json",
    ".yaml",
    ".yml",
    ".md",
    ".txt",
    ".csv",
    ".tex",
    ".xml",
    ".prj"
  ],
  "code_blocked_ext": [
    ".asv",
    ".fig",
    ".png",
    ".jpg",
    ".jpeg",
    ".zip",
    ".mat",
    ".xlsx",
    ".xls",
    ".pptx",
    ".docx",
    ".pdf"
  ],
  "always_include_names": [
    ".gitignore",
    ".gitattributes",
    "LICENSE"
  ]
}
